<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AcademiaSV</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AcademiaSv.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">🎓 AcademiaSV</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Alumnos" asp-action="Index">👨‍🎓 Alumnos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Maestros" asp-action="Index">👨‍🏫 Maestros</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Materias" asp-action="Index">📚 Materias</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Secciones" asp-action="Index">🏫 Secciones</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Inscripciones" asp-action="Index">📝 Inscripciones</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Reportes" asp-action="Index">📊 Reportes</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-3">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - AcademiaSV - Sistema de Gestión Académica
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
