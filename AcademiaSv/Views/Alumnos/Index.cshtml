@model IEnumerable<AcademiaSV.Models.Alumno>

@{
    ViewData["Title"] = "Alumnos";
}

<h2>Listado de Alumnos</h2>
<p>
    <a asp-controller="Alumnos" asp-action="Create" class="btn btn-primary">Nuevo Alumno</a>
</p>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Carnet</th>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Carrera</th>
            <th>Teléfono</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var alumno in Model)
        {
            <tr>
                <td>@alumno.carnet</td>
                <td>@alumno.nombre</td>
                <td>@alumno.apellido</td>
                <td>@alumno.Carrera?.nombre</td>
                <td>@alumno.telefono</td>
                <td>@alumno.estado</td>
                <td>
                    <a asp-controller="Alumnos" asp-action="Edit" asp-route-id="@alumno.id_alumno" class="btn btn-warning btn-sm">Editar</a>
                    <form asp-controller="Alumnos" asp-action="Delete" asp-route-id="@alumno.id_alumno" method="post" style="display:inline"
                          onsubmit="return confirm('¿Eliminar este alumno?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
