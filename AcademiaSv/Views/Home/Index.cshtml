@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mb-4">
    <h1 class="display-5 fw-bold">🎓 AcademiaSV</h1>
    <p class="lead text-muted">Sistema de Gestión Académica</p>
</div>

@* Tarjetas de resumen desde el microservicio *@
@if (ViewBag.Resumen != null)
{
    var r = ViewBag.Resumen;
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Alumnos Activos</h6>
                        <h2 class="mb-0">@r.AlumnosActivos</h2>
                        <small>de @r.TotalAlumnos totales</small>
                    </div>
                    <span style="font-size:2.5rem">👨‍🎓</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Maestros</h6>
                        <h2 class="mb-0">@r.TotalMaestros</h2>
                        <small>registrados</small>
                    </div>
                    <span style="font-size:2.5rem">👨‍🏫</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Materias</h6>
                        <h2 class="mb-0">@r.TotalMaterias</h2>
                        <small>activas</small>
                    </div>
                    <span style="font-size:2.5rem">📚</span>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card text-white bg-info h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Secciones</h6>
                        <h2 class="mb-0">@r.TotalSecciones</h2>
                        <small>abiertas</small>
                    </div>
                    <span style="font-size:2.5rem">🏫</span>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card text-white bg-danger h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title mb-0">Inscripciones Activas</h6>
                        <h2 class="mb-0">@r.InscripcionesActivas</h2>
                        <small>de @r.TotalInscripciones totales</small>
                    </div>
                    <span style="font-size:2.5rem">📝</span>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-secondary">
        <small>⚠️ No se pudo conectar al microservicio de reportes.</small>
    </div>
}

@* Notificaciones del microservicio *@
<h5 class="mb-3">🔔 Notificaciones del Sistema</h5>
@{
    var notificaciones = ViewBag.Notificaciones as List<AcademiaSV.Controllers.NotificacionDto>;
}
@if (notificaciones != null && notificaciones.Any())
{
    foreach (var n in notificaciones)
    {
        <div class="alert alert-@n.Nivel d-flex align-items-center mb-2" role="alert">
            <div>
                <strong>[@n.Tipo]</strong> @n.Mensaje
                <small class="text-muted ms-2">@n.FechaGeneracion.ToString("dd/MM/yyyy HH:mm")</small>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-light">No hay notificaciones disponibles.</div>
}

@* Accesos rápidos *@
<h5 class="mt-4 mb-3">⚡ Accesos Rápidos</h5>
<div class="row g-3">
    <div class="col-md-4">
        <a asp-controller="Alumnos" asp-action="Create" class="btn btn-outline-primary w-100">
            ➕ Nuevo Alumno
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Inscripciones" asp-action="Create" class="btn btn-outline-success w-100">
            ➕ Nueva Inscripción
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Reportes" asp-action="Index" class="btn btn-outline-secondary w-100">
            📊 Ver Reportes
        </a>
    </div>
</div>
